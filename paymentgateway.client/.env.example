# Backend API Configuration
VITE_API_BASE_URL=http://localhost:5550

# Optional for Turnstile integration (Phase 2)
# In production, set a real site key from Cloudflare dashboard.
VITE_TURNSTILE_SITE_KEY=

# Optional development bypass token (must match backend Turnstile:DevelopmentBypassToken)
VITE_TURNSTILE_DEV_BYPASS_TOKEN=dev-turnstile-bypass
